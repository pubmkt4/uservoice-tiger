# Streamlit Cloud secrets 설정 예시
# 이 파일을 참고해서 Streamlit Cloud > App settings > Secrets에 붙여넣기

[youtube]
api_key = "여기에_YouTube_API_키"

[gcp]
project_id = "o-pubmkt4-team"
region     = "us-east5"

# GCP Service Account JSON (Streamlit Cloud 배포 필수)
# GCP Console > IAM > 서비스 계정 > 키 생성(JSON) 후 내용 전체 붙여넣기
service_account_json = '''
{
  "type": "service_account",
  "project_id": "o-pubmkt4-team",
  "private_key_id": "...",
  "private_key": "-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n",
  "client_email": "...",
  "client_id": "...",
  "auth_uri": "https://accounts.google.com/o/oauth2/auth",
  "token_uri": "https://oauth2.googleapis.com/token"
}
'''
